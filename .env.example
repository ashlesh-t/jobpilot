# ─── JobPilot secrets ────────────────────────────────────────────────────────
# Copy this file to ~/.claude/job-hunt-ai/.env and fill in the values.
# setup.sh does the copy for you. NEVER commit the filled-in .env.
# See GETTING_STARTED.md for step-by-step instructions on obtaining each value.

# REQUIRED — Apify API token (https://console.apify.com/account/integrations)
APIFY_TOKEN=your_apify_api_token

# REQUIRED — Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# REQUIRED — Your Telegram chat ID (see GETTING_STARTED.md "Find your chat ID")
TELEGRAM_CHAT_ID=your_telegram_chat_id

# OPTIONAL — Path to a Google service-account JSON key, only needed if you want
# automatic Google Drive uploads via the REST fallback (skip it if you use the
# Drive MCP connector, or don't want Drive uploads at all).
GOOGLE_SERVICE_ACCOUNT_JSON=

# OPTIONAL — Override where JobPilot stores its data (default shown).
JOBPILOT_DIR=~/.claude/job-hunt-ai
